# Anthropic API key — required for AI theme/palette generation
ANTHROPIC_API_KEY=sk-ant-...

# Custom base URL (optional — for proxy/gateway)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model ID (optional — defaults to claude-sonnet-5)
# CLAUDE_MODEL=claude-sonnet-5

# Server port (optional — defaults to 3000)
# PORT=3000

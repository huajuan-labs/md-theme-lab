# AI provider config — supports any OpenAI-compatible or Anthropic endpoint
# 下方三选一，取消注释你要用的那个

# --- Agnes (免费, OpenAI 兼容) ---
API_KEY=sk-...
API_BASE_URL=https://apihub.agnes-ai.com/v1
AI_MODEL=agnes-2.0-flash

# --- OpenAI ---
# API_KEY=sk-proj-...
# API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# --- Anthropic Claude ---
# API_KEY=sk-ant-...
# API_BASE_URL=https://api.anthropic.com
# AI_MODEL=claude-sonnet-5

# --- 其他 OpenAI 兼容 (OpenRouter / Ollama / Deepseek 等) ---
# API_KEY=sk-or-...
# API_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=deepseek/deepseek-chat

# Image generation model (optional, Agnes 文生图)

# Server port
PORT=19527

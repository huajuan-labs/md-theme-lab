# AI provider config — supports any OpenAI-compatible or Anthropic endpoint
# 下方三选一，取消注释你要用的那个

# --- Agnes (免费, OpenAI 兼容) ---
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_BASE_URL=https://apihub.agnes-ai.com/v1
CLAUDE_MODEL=agnes-2.0-flash

# --- OpenAI ---
# ANTHROPIC_API_KEY=sk-proj-...
# ANTHROPIC_BASE_URL=https://api.openai.com/v1
# CLAUDE_MODEL=gpt-4o

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# CLAUDE_MODEL=claude-sonnet-5

# --- 其他 OpenAI 兼容 (OpenRouter / Ollama / Deepseek 等) ---
# ANTHROPIC_API_KEY=sk-or-...
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# CLAUDE_MODEL=deepseek/deepseek-chat

# Image generation model (optional, Agnes 文生图)
# IMAGE_MODEL=agnes-image-2.1-flash

# Server port
PORT=19527
